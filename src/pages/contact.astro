---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactPage from '../views/static/ContactPage'
const BASE_TITLE = 'Luxera · لوکسرا'

const contactJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'تماس با لوکسرا',
  description: 'با تیم پشتیبانی لوکسرا از طریق واتس‌اپ، تلگرام یا فرم تماس در ارتباط باشید. پاسخگویی سریع در روزهای کاری برای تمام سوالات خرید و ارسال.',
  url: 'https://luxera.ir/contact',
  mainEntity: {
    '@type': 'Organization',
    name: 'لوکسرا',
    url: 'https://luxera.ir',
    contactPoint: { '@type': 'ContactPoint', contactType: 'customer service', availableLanguage: 'Persian' },
  },
})
---

<BaseLayout
  title={`تماس با لوکسرا و پشتیبانی فروشگاه | ${BASE_TITLE}`}
  description="با تیم پشتیبانی لوکسرا از طریق واتس‌اپ، تلگرام یا فرم تماس در ارتباط باشید. پاسخگویی سریع در روزهای کاری برای تمام سوالات خرید و ارسال."
  canonical="/contact"
  jsonLd={contactJsonLd}
>
  <h1 class="sr-only">تماس با لوکسرا</h1>
  <p class="sr-only">
    برای تماس با تیم پشتیبانی لوکسرا می‌توانید از فرم زیر، واتس‌اپ، تلگرام یا ایمیل استفاده کنید.
    تیم پشتیبانی لوکسرا روزانه از ساعت ۱۰ صبح تا ۱۰ شب پاسخگوی سوالات شما درباره محصولات، سفارش‌ها،
    ارسال، بازگشت کالا، و همکاری با ما است. برای پیگیری سفارش کد رهگیری خود را از طریق واتس‌اپ ارسال
    کنید. درخواست‌های بازگشت و تعویض در کمتر از ۲۴ ساعت بررسی می‌شوند. سوالات درباره سایز، جنس و
    روکش محصولات را می‌توانید قبل از خرید مطرح کنید تا بهترین انتخاب را داشته باشید. لوکسرا به
    رضایت مشتریان اهمیت زیادی می‌دهد و هدف ما پاسخگویی سریع و مفید به تمام درخواست‌هاست.
    سریع‌ترین راه ارتباط با لوکسرا واتس‌اپ است؛ پیام‌های واتس‌اپ معمولاً در کمتر از یک ساعت در
    ساعات کاری پاسخ داده می‌شوند و می‌توانید عکس محصول، شماره سفارش یا سوال خود را مستقیم ارسال
    کنید. برای پیگیری وضعیت ارسال، شماره سفارش یا کد رهگیری پستی را آماده داشته باشید تا کارشناسان
    سریع‌تر راهنمایی‌تان کنند. اگر قصد تعویض سایز یا بازگشت کالا را دارید، پیش از ارسال مرجوعی با
    پشتیبانی هماهنگ کنید تا مراحل بازگشت و استرداد وجه به‌درستی ثبت شود. تیم لوکسرا همچنین آماده‌ی
    پاسخگویی به درخواست‌های همکاری، خرید عمده، تأمین جواهرات برای فروشگاه‌ها و پیشنهاد محصول جدید
    است. برای دریافت مشاوره‌ی انتخاب هدیه، انتخاب ست مناسب یا راهنمایی درباره‌ی نگهداری از جواهرات
    فانتزی نیز می‌توانید با ما در تماس باشید. پیام‌هایی که خارج از ساعات کاری ثبت می‌شوند، در اولین
    فرصت روز کاری بعد بررسی و پاسخ داده خواهند شد. رضایت و اعتماد مشتری مهم‌ترین اولویت لوکسرا است.
  </p>
  <ContactPage client:load />
</BaseLayout>
