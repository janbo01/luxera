---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProductPage from '../../views/ProductPage'
import { fetchProductData, fetchFooterData, safeJson } from '../../lib/ssr'

const { id } = Astro.params

const [{ initialData, lcpPreload, initialScript }, footerData] = await Promise.all([
  fetchProductData(id!),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

const product = (initialData as { product?: Record<string, unknown> }).product
const BASE_TITLE = 'Luxera · لوکسرا'
const h1Title = (product?.seo_title ?? product?.title_fa ?? product?.title ?? 'محصول') as string
const title = product
  ? `${h1Title} | ${BASE_TITLE}`
  : `محصول | ${BASE_TITLE}`
const description = product
  ? ((product.seo_description ?? product.short_description ?? '') as string)
  : undefined
const ogImage = (product?.images as Array<{ url: string }> | undefined)?.[0]?.url

const productSlug = (product?.slug ?? id) as string
const productUrl = `https://luxera.ir/product/${productSlug}`
const productJsonLd = product ? safeJson({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: h1Title,
  description: ((product.seo_description ?? product.short_description ?? '') as string) || undefined,
  image: (product.images as Array<{ url: string }> | undefined)?.map((img) => img.url) ?? [],
  url: productUrl,
  sku: productSlug,
  brand: { '@type': 'Brand', name: 'لوکسرا' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'IRR',
    price: String(product.price ?? ''),
    availability: 'https://schema.org/InStock',
    url: productUrl,
  },
}) : undefined
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/product/${id}`}
  ogType="product"
  lcpPreload={lcpPreload}
  jsonLd={productJsonLd}
>
  <h1 class="sr-only">{h1Title}</h1>
  <Fragment set:html={initialScript + footerScript} />
  <ProductPage client:only="react" id={id!} initialData={initialData} />
</BaseLayout>
