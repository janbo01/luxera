---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProductPage from '../../views/ProductPage'
import { fetchProductData, fetchFooterData, safeJson } from '../../lib/ssr'

const { id } = Astro.params

const [{ initialData, lcpPreload, initialScript }, footerData] = await Promise.all([
  fetchProductData(id!),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

const product = (initialData as { product?: Record<string, unknown> }).product
const BASE_TITLE = 'Luxera · لوکسرا'
const h1Title = (product?.seo_title ?? product?.title_fa ?? product?.title ?? 'محصول') as string
const title = product
  ? `${h1Title} | ${BASE_TITLE}`
  : `محصول | ${BASE_TITLE}`
const description = product
  ? ((product.seo_description ?? product.short_description ?? '') as string)
  : undefined
const ogImage = (product?.images as Array<{ url: string }> | undefined)?.[0]?.url

const productSlug = (product?.slug ?? id) as string
const productBodyText = product
  ? [
      product.seo_description as string | undefined,
      product.short_description as string | undefined,
      product.description as string | undefined,
    ]
      .filter(Boolean)
      .join(' ')
  : ''
const productUrl = `https://luxera.ir/product/${productSlug}`

// Reviews/rating for structured data — mirrors the client JSON-LD in ProductPage so the
// SSR markup Google crawls already carries aggregateRating + review (fixes GSC "Missing
// field review"). Built from real, on-page customer comments; only emitted when they exist.
const productComments = ((initialData as { productComments?: Array<Record<string, unknown>> })
  .productComments ?? [])
const reviewCount = typeof product?.review_count === 'number' ? (product.review_count as number) : 0
const ratingValue = typeof product?.rating === 'number' ? (product.rating as number) : 0

const productNode: Record<string, unknown> = {
  '@type': 'Product',
  name: h1Title,
  description: ((product?.seo_description ?? product?.short_description ?? '') as string) || undefined,
  image: (product?.images as Array<{ url: string }> | undefined)?.map((img) => img.url) ?? [],
  url: productUrl,
  sku: productSlug,
  brand: { '@type': 'Brand', name: 'لوکسرا' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'IRR',
    price: String(product?.price ?? ''),
    availability: 'https://schema.org/InStock',
    url: productUrl,
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'IR',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: 4,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn',
      returnPolicyLink: 'https://luxera.ir/shipping',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: { '@type': 'MonetaryAmount', value: '180000', currency: 'IRR' },
      shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'IR' },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 1, unitCode: 'DAY' },
        transitTime: { '@type': 'QuantitativeValue', minValue: 1, maxValue: 5, unitCode: 'DAY' },
      },
    },
  },
}

if (reviewCount > 0) {
  productNode.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: String(Math.max(ratingValue, 1)),
    reviewCount: String(reviewCount),
    bestRating: '5',
    worstRating: '1',
  }
}

if (productComments.length > 0) {
  productNode.review = productComments.slice(0, 5).map((c, i) => ({
    '@type': 'Review',
    author: {
      '@type': 'Person',
      name: `کاربر ${(c.user_id as string | undefined)?.slice(0, 4) || String(i + 1)}`,
    },
    datePublished: (c.created_at as string | undefined)?.slice(0, 10),
    reviewBody: c.content,
    reviewRating: {
      '@type': 'Rating',
      ratingValue: String((c.rating as number | undefined) || 5),
      bestRating: '5',
      worstRating: '1',
    },
  }))
}

const productJsonLd = product
  ? safeJson({ '@context': 'https://schema.org', ...productNode })
  : undefined
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/product/${id}`}
  ogType="product"
  lcpPreload={lcpPreload}
  jsonLd={productJsonLd}
>
  <h1 class="sr-only">{h1Title}</h1>
  {productBodyText && <p class="sr-only">{productBodyText}</p>}
  <p class="sr-only">
    خرید آنلاین از لوکسرا — فروشگاه تخصصی جواهرات فانتزی با آلیاژ بدون نیکل و روکش ماندگار.
    بسته‌بندی هدیه‌ای استاندارد، ارسال یک‌روزه در تهران و ۲ تا ۴ روز در سراسر ایران.
    بازگشت رایگان تا ۴ روز پس از دریافت.
  </p>
  <Fragment set:html={initialScript + footerScript} />
  <ProductPage client:only="react" id={id!} initialData={initialData} />
</BaseLayout>
