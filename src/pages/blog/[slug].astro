---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetailPage from '../../views/BlogDetailPage'
import { fetchBlogPostData, fetchFooterData, safeJson } from '../../lib/ssr'

const { slug } = Astro.params
const BASE_TITLE = 'Luxera · لوکسرا'

const [{ initialData, lcpPreload, initialScript }, footerData] = await Promise.all([
  fetchBlogPostData(slug!),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

const post = (initialData as { blogPost?: Record<string, unknown> }).blogPost
const h1Title = (post?.title ?? 'مقاله') as string
const title = post
  ? `${(post.seo_title ?? h1Title) as string} | ${BASE_TITLE}`
  : `مقاله | ${BASE_TITLE}`
const description = (post?.seo_description ?? post?.excerpt ?? '') as string
const ogImage = (post?.featured_image_url ?? '') as string

const blogJsonLd = post ? safeJson({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: (post.seo_title ?? post.title) as string,
  description: (post.seo_description ?? post.excerpt ?? '') as string || undefined,
  image: post.featured_image_url ?? undefined,
  datePublished: post.published_at ?? post.created_at,
  dateModified: post.updated_at,
  author: { '@type': 'Person', name: 'تیم لوکسرا', url: 'https://luxera.ir/about' },
  publisher: { '@type': 'Organization', name: 'لوکسرا', url: 'https://luxera.ir' },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://luxera.ir/blog/${slug}`,
  },
}) : undefined
---

<BaseLayout
  title={title}
  description={description || undefined}
  canonical={`/blog/${slug}`}
  ogImage={ogImage || undefined}
  lcpPreload={lcpPreload}
  jsonLd={blogJsonLd}
>
  <h1 class="sr-only">{h1Title}</h1>
  <Fragment set:html={initialScript + footerScript} />
  <BlogDetailPage client:only="react" slug={slug!} initialData={initialData} />
</BaseLayout>
