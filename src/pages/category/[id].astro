---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CategoryPage from '../../views/CategoryPage'
import { fetchCategoryData, fetchFooterData, safeJson } from '../../lib/ssr'
import { CATEGORIES } from '../../data/categories'

const { id } = Astro.params

const CATEGORY_SEO_TITLES: Record<string, string> = {
  necklaces: 'خرید گردنبند فانتزی زنانه',
  bracelets: 'خرید دستبند فانتزی زنانه',
  rings: 'خرید انگشتر فانتزی زنانه',
  earrings: 'خرید گوشواره فانتزی دخترانه',
  sets: 'خرید ست جواهرات فانتزی زنانه',
  new: 'جدیدترین محصولات جواهرات فانتزی',
  bridal: 'خرید جواهرات عروس و نامزدی فانتزی',
  mens: 'خرید جواهرات مردانه فانتزی',
}

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  necklaces: 'گردنبندهای فانتزی لوکسرا — گردنبندهای ظریف و شیک با روکش ماندگار، بدون نیکل، مناسب برای هر مناسبت. ارسال یک‌روزه در تهران.',
  bracelets: 'دستبندهای فانتزی لوکسرا — مدل‌های ظریف و شیک با روکش طلا و نقره، سایزبندی دقیق، بدون نیکل. ارسال سراسر ایران با ضمانت کیفیت یک‌ساله.',
  rings: 'انگشترهای فانتزی لوکسرا — انگشترهای شیک با طرح‌های متنوع، آلیاژ بدون نیکل، مناسب برای پوست حساس. ارسال یک‌روزه در تهران.',
  earrings: 'گوشواره‌های فانتزی لوکسرا — مدل‌های ظریف تا جسور با روکش ماندگار، بدون نیکل، مناسب برای هر سبک. ارسال یک‌روزه در تهران با ضمانت کیفیت.',
  sets: 'ست‌های جواهرات فانتزی لوکسرا — ست‌های هماهنگ گردنبند، دستبند و گوشواره با روکش ماندگار و بدون نیکل. گزینه‌ای عالی برای هدیه، ارسال سراسر ایران.',
  new: 'جدیدترین جواهرات فانتزی لوکسرا — آخرین طرح‌های گردنبند، انگشتر، دستبند و گوشواره با روکش ماندگار و بدون نیکل. بروزرسانی روزانه، ارسال سریع.',
  bridal: 'جواهرات عروس لوکسرا — ست‌های جواهرات عروسی و نامزدی با طراحی خاص و روکش ماندگار.',
  mens: 'جواهرات مردانه لوکسرا — دستبند، انگشتر و گردنبند مردانه با طراحی مدرن و آلیاژ بادوام.',
}

const CATEGORY_BODY_TEXT: Record<string, string> = {
  necklaces:
    'گردنبند فانتزی یکی از محبوب‌ترین انتخاب‌های بانوان ایرانی برای تکمیل استایل روزانه و مجلسی است. مجموعه لوکسرا شامل طرح‌های ظریف تک‌نگین، گردنبند لایه‌ای، قلب، ستاره، و مدل‌های بلند می‌شود که هر کدام برای سبک و مناسبت خاصی مناسب‌اند. همه گردنبندها از آلیاژ بدون نیکل ساخته شده‌اند که برای پوست حساس ایده‌آل است و روکش آنها در برابر تعریق روزانه و عطر مقاوم است. گردنبند یکی از بهترین هدایا برای تولد، عید نوروز، ولنتاین، مادرانه و سالگرد است. هر سفارش با جعبه اختصاصی لوکسرا همراه است و ضمانت کیفیت یک‌ساله شامل تعویض رایگان در صورت تغییر رنگ روکش می‌شود.',
  bracelets:
    'دستبند فانتزی از زیورآلات روزمره‌ای است که به هر ست لباسی شخصیت می‌بخشد. مجموعه دستبندهای لوکسرا شامل مدل‌های زنجیری ظریف، بنگل، حلقه‌ای، چرمی، و دستبندهای لایه‌ای می‌شود. سایزبندی دقیق محصولات امکان انتخاب مناسب را برای مچ‌های مختلف فراهم می‌کند. آلیاژ بدون نیکل و روکش مقاوم طلا یا نقره برای استفاده روزانه طراحی شده است. دستبند هدیه‌ای مناسب برای تولد، نامزدی، و ولنتاین است. ست دستبند با گردنبند و گوشواره هماهنگ نیز در مجموعه لوکسرا موجود است. بسته‌بندی هدیه‌ای استاندارد برای تمام سفارش‌ها. ضمانت کیفیت یک‌ساله و ارسال سریع به سراسر ایران.',
  rings:
    'انگشتر فانتزی با طرح‌های متنوع برای هر سلیقه‌ای در لوکسرا موجود است. از انگشترهای ظریف با نگین‌های کوچک تا مدل‌های جسور و پهن، مجموعه لوکسرا طیف وسیعی از انتخاب را ارائه می‌دهد. آلیاژ بدون نیکل برای پوست‌های حساس مناسب است و حساسیت پوستی ایجاد نمی‌کند. روکش طلا و نقره با دوام در برابر استفاده روزانه مقاوم است. انگشتر هدیه‌ای محبوب برای تولد، سالگرد، و مناسبت‌های خاص است. هر انگشتر در جعبه اختصاصی لوکسرا تحویل داده می‌شود. راهنمای سایز انگشتر در صفحه محصول موجود است. ضمانت یک‌ساله و ارسال سریع به تهران و سراسر ایران.',
  earrings:
    'گوشواره فانتزی برای هر سبک و مناسبتی در مجموعه لوکسرا موجود است. طرح‌های ظریف گل‌میخ برای استفاده روزانه، گوشواره‌های آویز و حلقه برای مجالس، و مدل‌های بلند برای رویدادهای خاص در این مجموعه یافت می‌شود. تمام گوشواره‌ها از آلیاژ بدون نیکل ساخته شده‌اند که پوست گوش را تحریک نمی‌کند. روکش مقاوم طلا و نقره برای استفاده مداوم مناسب است. گوشواره یکی از پرطرفدارترین هدایا برای تولد، ولنتاین، و مادرانه است. هر گوشواره در جعبه اختصاصی بسته‌بندی می‌شود. ضمانت کیفیت یک‌ساله برای تمام محصولات. ارسال یک‌روزه به تهران و ۲ تا ۴ روز به سراسر ایران.',
  sets:
    'ست جواهرات فانتزی بهترین راه برای داشتن ظاهری هماهنگ و شیک است. مجموعه ست‌های لوکسرا شامل ترکیب‌های گردنبند و گوشواره، گردنبند و دستبند، یا ست کامل سه‌تایی می‌شود. هماهنگی طرح، رنگ و متریال در ست‌های لوکسرا ظاهری یکدست و حرفه‌ای می‌سازد. همه قطعات از آلیاژ بدون نیکل با روکش مقاوم ساخته شده‌اند. ست جواهرات هدیه‌ای ایده‌آل برای تولد، نامزدی، عروسی و سالگرد است. ست‌های لوکسرا در جعبه‌ی هدیه اختصاصی با کیف پارچه‌ای آماده می‌شوند. ضمانت کیفیت یک‌ساله برای تمام قطعات ست. ارسال سریع به تهران و سراسر ایران.',
  new:
    'جدیدترین جواهرات فانتزی لوکسرا روزانه به‌روز می‌شود. آخرین ترندهای جهانی در طراحی گردنبند، انگشتر، دستبند و گوشواره در این بخش موجود است. تیم انتخاب لوکسرا با بررسی بازارهای بین‌المللی، طرح‌های روز را با کیفیت مطمئن انتخاب می‌کند. همه محصولات جدید از آلیاژ بدون نیکل با روکش مقاوم ساخته شده‌اند. ارسال سریع برای تمام سفارش‌ها. ضمانت کیفیت یک‌ساله.',
  bridal:
    'جواهرات عروس لوکسرا برای ویژه‌ترین روزهای زندگی طراحی شده‌اند. ست‌های جواهرات عروسی و نامزدی با طراحی‌های خاص، نگین‌های درخشان و روکش ماندگار در این مجموعه موجود است. همه محصولات از آلیاژ بدون نیکل ساخته شده‌اند. بسته‌بندی هدیه‌ای مخصوص برای جواهرات عروس. ضمانت کیفیت یک‌ساله.',
  mens:
    'جواهرات مردانه لوکسرا با طراحی مدرن و مینیمال برای آقایان ارائه شده است. دستبند، انگشتر و گردنبند مردانه با آلیاژ بادوام و طراحی بی‌تکلف در این مجموعه موجود است. مناسب برای استفاده روزانه و مجالس. ارسال سریع به سراسر ایران.',
}

const cat = CATEGORIES.find((c) => c.id === id)
const seoTitle = (id && CATEGORY_SEO_TITLES[id]) || cat?.fa || 'دسته‌بندی'
const BASE_TITLE = 'Luxera · لوکسرا'

const [{ initialData, initialScript }, footerData] = await Promise.all([
  fetchCategoryData(id!),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

type ProductLink = { id: string; slug?: string; title_fa?: string; title: string }
const productItems: ProductLink[] =
  (initialData as { categoryProducts?: { items?: ProductLink[] } })?.categoryProducts?.items ?? []

const categoryJsonLd = safeJson({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: seoTitle,
      description: id ? CATEGORY_DESCRIPTIONS[id] : undefined,
      url: `https://luxera.ir/category/${id}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'خانه', item: 'https://luxera.ir' },
        { '@type': 'ListItem', position: 2, name: seoTitle, item: `https://luxera.ir/category/${id}` },
      ],
    },
  ],
})
---

<BaseLayout
  title={`${seoTitle} | ${BASE_TITLE}`}
  description={id ? CATEGORY_DESCRIPTIONS[id] : undefined}
  canonical={`/category/${id}`}
  jsonLd={categoryJsonLd}
>
  <h1 class="sr-only">{seoTitle}</h1>
  <Fragment set:html={initialScript + footerScript} />
  {id && CATEGORY_BODY_TEXT[id] && (
    <p class="sr-only">{CATEGORY_BODY_TEXT[id]}</p>
  )}
  <p class="sr-only">
    لوکسرا فروشگاه تخصصی جواهرات فانتزی در ایران است. تمام محصولات از آلیاژ بدون نیکل ساخته شده‌اند
    و روکش آنها در برابر تعریق، عطر و رطوبت روزانه مقاوم است. هر قطعه پیش از ورود به فهرست لوکسرا
    آزمون کیفیت می‌شود تا از ماندگاری روکش و سلامت پوست اطمینان حاصل شود. ضمانت کیفیت یک‌ساله
    شامل تعویض رایگان در صورت تغییر رنگ روکش می‌شود. بسته‌بندی هدیه‌ای استاندارد برای تمام سفارش‌ها
    بدون هزینه اضافی ارائه می‌شود. ارسال یک‌روزه در تهران و ۲ تا ۴ روز کاری در سراسر ایران. بازگشت
    رایگان تا ۴ روز پس از دریافت. پشتیبانی آنلاین روزانه از ساعت ۱۰ تا ۲۲ از طریق واتس‌اپ و فرم تماس.
  </p>
  {productItems.length > 0 && (
    <nav aria-hidden="true" class="sr-only">
      {productItems.map(p => <a href={`/product/${p.slug ?? p.id}`}>{p.title_fa ?? p.title}</a>)}
    </nav>
  )}
  <CategoryPage client:only="react" id={id!} initialData={initialData} />
</BaseLayout>
