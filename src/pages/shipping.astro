---
import BaseLayout from '../layouts/BaseLayout.astro'
import ShippingPage from '../views/static/ShippingPage'
const BASE_TITLE = 'Luxera · لوکسرا'

const shippingJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'ارسال و بازگشت — لوکسرا',
  description: 'جزئیات ارسال و بازگشت لوکسرا — تحویل یک‌روزه در تهران، ۲ تا ۴ روز کاری در سراسر ایران. همه سفارش‌ها بیمه‌دار و با کد رهگیری. بازگشت تا ۴ روز.',
  url: 'https://luxera.ir/shipping',
  isPartOf: { '@type': 'WebSite', name: 'لوکسرا', url: 'https://luxera.ir' },
})
---

<BaseLayout
  title={`ارسال و تحویل | شرایط و هزینه پست لوکسرا | ${BASE_TITLE}`}
  description="جزئیات ارسال و بازگشت لوکسرا — تحویل یک‌روزه در تهران، ۲ تا ۴ روز کاری در سراسر ایران. همه سفارش‌ها بیمه‌دار و با کد رهگیری. بازگشت تا ۴ روز."
  canonical="/shipping"
  jsonLd={shippingJsonLd}
>
  <h1 class="sr-only">ارسال و بازگشت</h1>
  <ShippingPage client:load />
</BaseLayout>
