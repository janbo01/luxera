---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CollectionDetailPage from '../../views/CollectionDetailPage'
import { fetchCollectionData, fetchFooterData, safeJson } from '../../lib/ssr'

const { slug } = Astro.params
const BASE_TITLE = 'Luxera · لوکسرا'

const [{ initialData, lcpPreload, initialScript }, footerData] = await Promise.all([
  fetchCollectionData(slug!),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

const col = (initialData as { collection?: Record<string, unknown> }).collection
const colName = (col?.name_fa ?? 'مجموعه') as string
const title = col
  ? `${colName} | ${BASE_TITLE}`
  : `مجموعه | ${BASE_TITLE}`
const description = (col?.description ?? '') as string

const collectionJsonLd = col ? safeJson({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: colName,
      description: description || undefined,
      url: `https://luxera.ir/collections/${slug}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'خانه', item: 'https://luxera.ir' },
        { '@type': 'ListItem', position: 2, name: 'مجموعه‌ها', item: 'https://luxera.ir/collections' },
        { '@type': 'ListItem', position: 3, name: colName, item: `https://luxera.ir/collections/${slug}` },
      ],
    },
  ],
}) : undefined
---

<BaseLayout
  title={title}
  description={description || undefined}
  canonical={`/collections/${slug}`}
  lcpPreload={lcpPreload}
  jsonLd={collectionJsonLd}
>
  <h1 class="sr-only">{colName}</h1>
  {description && <p class="sr-only">{description}</p>}
  <p class="sr-only">
    مجموعه‌ی «{colName}» گزیده‌ای از جواهرات فانتزی لوکسرا با طراحی هماهنگ است که قطعات آن از نظر
    طرح، رنگ و متریال با یکدیگر ست می‌شوند تا ظاهری یکدست و حرفه‌ای بسازند. تمام قطعات این مجموعه
    از آلیاژ بدون نیکل با روکش مقاوم طلا یا نقره ساخته شده‌اند که برای پوست حساس ایمن است و در برابر
    تعریق، عطر و رطوبت روزانه مقاومت می‌کند. هر قطعه پیش از ورود به فهرست لوکسرا آزمون کیفیت می‌شود
    تا از ماندگاری روکش و سلامت پوست اطمینان حاصل شود. این مجموعه گزینه‌ای مناسب برای هدیه‌ی تولد،
    نامزدی، سالگرد و مناسبت‌های خاص است و قطعات آن در جعبه‌ی هدیه‌ی اختصاصی همراه با کیف پارچه‌ای
    آماده می‌شوند. خرید مجموعه‌ی آماده در زمان شما صرفه‌جویی می‌کند و خیال‌تان را از بابت هماهنگی
    قطعات راحت می‌گذارد. تمام محصولات لوکسرا از آلیاژ بدون نیکل با روکش مقاوم در برابر تعریق و عطر
    ساخته می‌شوند. ارسال یک‌روزه در تهران و ۲ تا ۴ روز کاری در سراسر ایران انجام می‌شود و
    بازگشت کالا تا ۴ روز پس از دریافت امکان‌پذیر است. برای مشاوره‌ی انتخاب مجموعه یا راهنمایی درباره‌ی
    سایز و نگهداری، پشتیبانی لوکسرا روزانه از ساعت ۱۰ تا ۲۲ از طریق واتس‌اپ و فرم تماس پاسخگوست.
  </p>
  <Fragment set:html={initialScript + footerScript} />
  <CollectionDetailPage client:only="react" slug={slug!} initialData={initialData} />
</BaseLayout>
