---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CollectionsPage from '../../views/CollectionsPage'
import { fetchCollectionsListData, fetchFooterData, safeJson } from '../../lib/ssr'

const BASE_TITLE = 'Luxera · لوکسرا'

const [{ initialData, initialScript }, footerData] = await Promise.all([
  fetchCollectionsListData(),
  fetchFooterData(),
])

const footerScript = footerData.categories.length > 0 || footerData.collections.length > 0
  ? `<script>window.__FOOTER_INITIAL__=${safeJson(footerData)}</script>`
  : ''

type CollectionLink = { slug: string; name_fa: string }
const collectionItems: CollectionLink[] =
  (initialData as { collections?: CollectionLink[] })?.collections ?? []

const collectionsJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'مجموعه‌های اختصاصی جواهرات لوکسرا',
  description: 'مجموعه‌های اختصاصی جواهرات فانتزی لوکسرا — ست‌های طراحی‌شده برای هر سبک و مناسبت. از مجموعه‌های رمانتیک تا مدرن، با روکش ماندگار و بدون نیکل.',
  url: 'https://luxera.ir/collections',
  isPartOf: { '@type': 'WebSite', name: 'لوکسرا', url: 'https://luxera.ir' },
})
---

<BaseLayout
  title={`مجموعه‌های اختصاصی جواهرات لوکسرا | ${BASE_TITLE}`}
  description="مجموعه‌های اختصاصی جواهرات فانتزی لوکسرا — ست‌های طراحی‌شده برای هر سبک و مناسبت. از مجموعه‌های رمانتیک تا مدرن، با روکش ماندگار و بدون نیکل."
  canonical="/collections"
  jsonLd={collectionsJsonLd}
>
  <h1 class="sr-only">مجموعه‌های اختصاصی جواهرات لوکسرا</h1>
  <p class="sr-only">
    مجموعه‌های اختصاصی لوکسرا گزیده‌ای از جواهرات فانتزی با طراحی هماهنگ برای هر سبک و مناسبت هستند.
    برخلاف خرید تکی، هر مجموعه شامل قطعاتی است که از نظر طرح، رنگ و متریال با یکدیگر ست می‌شوند و
    ظاهری یکدست و حرفه‌ای می‌سازند. مجموعه‌های لوکسرا طیف گسترده‌ای از سبک‌ها را پوشش می‌دهند:
    از مدل‌های رمانتیک و ظریف با نگین‌های ریز تا طرح‌های مدرن و جسور با لاین‌های هندسی. همه قطعات
    هر مجموعه از آلیاژ بدون نیکل با روکش مقاوم طلا یا نقره ساخته شده‌اند که برای پوست حساس ایمن است
    و در برابر تعریق و عطر روزانه مقاومت می‌کنند. مجموعه‌های لوکسرا هدیه‌ای ایده‌آل برای تولد، نامزدی،
    سالگرد عروسی و عید هستند چون قطعات داخل یک جعبه هدیه اختصاصی همراه با کیف پارچه‌ای آماده می‌شوند
    و نیازی به انتخاب جداگانه ندارید. تیم لوکسرا با بررسی دقیق برندهای معتبر بین‌المللی، هر مجموعه را
    بر اساس سه معیار کیفیت روکش، ایمنی پوست، و ماندگاری طرح انتخاب می‌کند. در هر فصل مجموعه‌های جدیدی
    با الهام از ترندهای بین‌المللی اضافه می‌شوند. انتخاب یک مجموعه‌ی آماده، در زمان شما صرفه‌جویی
    می‌کند و خیال‌تان را از بابت هماهنگی قطعات راحت می‌کند؛ به‌جای اینکه گردنبند، گوشواره و دستبند را
    جداگانه بسنجید، یک ست هماهنگ و حرفه‌ای دریافت می‌کنید که طراحان لوکسرا آن را کنار هم چیده‌اند.
    هر مجموعه برای سبک و مناسبت مشخصی طراحی شده است: مجموعه‌های مینیمال برای استفاده‌ی روزمره و محیط
    کار، مجموعه‌های درخشان و مجلسی برای مهمانی و عروسی، و مجموعه‌های کلاسیک به‌عنوان هدیه‌ای ماندگار.
    قیمت‌گذاری مجموعه‌ها معمولاً به‌صرفه‌تر از خرید تک‌تک قطعات است و امکان مقایسه‌ی آسان میان
    مجموعه‌های مختلف فراهم شده است. با بازگشت رایگان تا ۴ روز و ارسال سریع به تهران و سراسر ایران، خرید
    مجموعه جواهرات از لوکسرا تجربه‌ای مطمئن و راحت است.
  </p>
  <Fragment set:html={initialScript + footerScript} />
  {collectionItems.length > 0 && (
    <nav aria-hidden="true" class="sr-only">
      {collectionItems.map(col => <a href={`/collections/${col.slug}`}>{col.name_fa}</a>)}
    </nav>
  )}
  <CollectionsPage client:only="react" initialData={initialData} />
</BaseLayout>
