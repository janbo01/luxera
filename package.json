{
  "name": "luxera",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:ssr && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "build:server": "esbuild server.ts --platform=node --format=esm --bundle --packages=external --outfile=dist/server.js",
    "preview": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-date-object": "^2.1.9",
    "react-dom": "^19.2.6",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.19.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-compression": "^0.5.1"
  }
}
