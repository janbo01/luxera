{
  "name": "luxera",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:ssr && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "build:server": "esbuild server.ts --platform=node --format=esm --bundle --packages=external --outfile=dist/server.js",
    "preview": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-date-object": "^2.1.9",
    "react-dom": "^19.2.7",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1"
  }
}
